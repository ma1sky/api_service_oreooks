generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    tg_id    Int      @id
    token    String
    tasks    Task[]
    students Student?

    @@map("users")
}

model Student {
    id              Int    @id @default(autoincrement())
    course          Int
    department      String
    full_name       String
    group           String
    record_book_id  Int
    semester        Int
    study_direction String
    study_profile   String
    year            String
    userId          Int    @unique
    user            User   @relation(fields: [userId], references: [tg_id])

    @@map("students")
}

model Task {
    id          Int      @id @default(autoincrement())
    title       String
    description String?
    deadline    DateTime
    authorId    Int
    author      User     @relation(fields: [authorId], references: [tg_id])

    @@map("tasks")
}

model Event {
    discipline    String
    id            Int     @id
    alias         String?
    current_grade Float?
    max_grade     Float?
    name          String?
    type          String
    week          Int

    @@map("events")
}
